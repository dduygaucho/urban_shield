# Copy to .env (never commit .env):
#   cp services/api/.env.example services/api/.env
#
# Optional: restrict CORS in production (comma-separated origins). Empty = allow all for local dev.
# CORS_ORIGINS=http://localhost:3000

# SQLite path relative to services/api working directory when you `cd services/api && uvicorn ...`
DATABASE_URL=sqlite:///./urban_shield.db

# Scheduled news/social ingestion. Disabled by default for local dev.
INGEST_ENABLED=false
INGEST_INTERVAL_SECONDS=1800

# Comma-separated RSS feed URLs. Leave empty to run Reddit-only until feeds are chosen.
INGEST_RSS_FEEDS=

# Comma-separated Reddit search queries.
INGEST_REDDIT_QUERIES=melbourne fight,melbourne robbery,geelong suspicious,melbourne attack
# Optional: path to Agent-F `transport_route_geometries_vic.geojson` for GET /data/transport_route_geometries_vic.geojson
# (defaults to scratch path used by ingest; set if your file lives elsewhere).
# TRANSPORT_ROUTE_GEOJSON_PATH=/scratch/s224714149/sidework/urban_shield/transport_gtfs/transport_route_geometries_vic.geojson
