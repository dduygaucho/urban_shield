# Copy to `.env.local` (Next.js reads this for local dev). NEVER commit `.env.local`.
#
#   cp apps/web/.env.example apps/web/.env.local
#
# `*.local` and `.env` are gitignored — keep real tokens only in `.env.local`.

# FastAPI base URL (no trailing slash). Default dev: API on port 8000.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Mapbox token for Mapbox GL in the browser — MUST be a PUBLIC token (starts with pk.).
# Do NOT paste a secret token (sk.*); Mapbox GL will reject it. Account → Tokens → default public token.
NEXT_PUBLIC_MAPBOX_TOKEN=

# Default map center when GPS is off, denied, or outside the Victoria box: melbourne | geelong
# (Map still shows both cities in one regional view; this only picks the fallback center.)
NEXT_PUBLIC_MAP_DEFAULT=melbourne
