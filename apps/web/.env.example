# Copy to `.env.local` (Next.js reads this for local dev). NEVER commit `.env.local`.
#
#   cp apps/web/.env.example apps/web/.env.local
#
# `*.local` and `.env` are gitignored — keep real tokens only in `.env.local`.

# FastAPI base URL (no trailing slash). Default dev: API on port 8000.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Mapbox public access token (from Mapbox account — safe to expose in browser with URL restrictions).
NEXT_PUBLIC_MAPBOX_TOKEN=
